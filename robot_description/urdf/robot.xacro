<?xml version="1.0"?>
<robot name="robot" xmlns:xacro="http://ros.org/wiki/xacro"> 

<!-- =============================================================== 
                            [LINKS]
================================================================ -->
    <!-- ─────────────────────────────────────────────
        [LINKS] BASE FOOTPRINT
    ────────────────────────────────────────────── -->
    <link name="base_footprint"/>

    <!-- ─────────────────────────────────────────────
        [LINKS] BASE LINK
    ────────────────────────────────────────────── -->
    <link name="base_link">
        <inertial>
            <origin xyz="0.049 -0.002 0.219" rpy="0.0 0.0 0.0"/>
            <mass value="6.32"/>
            <inertia ixx="0.078" ixy="1.027E-05" ixz="-3.324E-05" 
                    iyy="0.089" iyz="4.051E-07" izz="0.059"/>
        </inertial>

        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/base_link.STL" scale="1 1 1"/>
            </geometry>
            <material name="material_base_link">
                <color rgba="0.52 0.55 0.81 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/base_link.STL" scale="1 1 1"/>
            </geometry>
        </collision>
    </link>

    <!-- ─────────────────────────────────────────────
        [LINKS] WHEEL LEFT
    ────────────────────────────────────────────── -->
    <link name="wheel_left_link">
        <inertial>
            <origin xyz="-0.014 0.001 -0.033" rpy="0.0 0.0 0.0"/>
            <mass value="0.7"/>
            <inertia ixx="0.001" ixy="7.908E-21" ixz="-3.057E-20" 
                    iyy="0.002" iyz="4.986E-20" izz="0.001"/>
        </inertial>

        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/wheel_left.STL" scale="1 1 1"/>
            </geometry>
            <material name="material_wheel_left">
                <color rgba="0.15 0.15 0.15 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/wheel_left.STL" scale="1 1 1"/>
            </geometry>
        </collision>
    </link>

    <!-- ─────────────────────────────────────────────
        [LINKS] WHEEL RIGHT
    ────────────────────────────────────────────── -->
    <link name="wheel_right_link">
        <inertial>
            <origin xyz="-0.014 0.001 -0.033" rpy="0.0 0.0 0.0"/>
            <mass value="0.7"/>
            <inertia ixx="0.001" ixy="5.125E-22" ixz="-3.493E-20"
                     iyy="0.002" iyz="2.955E-22" izz="0.001"/>
        </inertial>

        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/wheel_right.STL" scale="1 1 1"/>
            </geometry>
            <material name="material_wheel_right">
                <color rgba="0.15 0.15 0.15 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/wheel_right.STL" scale="1 1 1"/>
            </geometry>
        </collision>
    </link>

    <!-- ─────────────────────────────────────────────
        [LINKS] CASTER LEFT
    ────────────────────────────────────────────── -->
    <link name="caster_left_link">
        <inertial>
            <origin xyz="-0.014 0.001 -0.033" rpy="0.0 0.0 0.0"/>
            <mass value="0.1"/>
            <inertia ixx="2.433E-05" ixy="3.222E-05" ixz="-2.152E-05" 
                    iyy="2.851E-05" iyz="3.766E-07" izz="2.982E-05"/>
        </inertial>

        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/caster_left.STL" scale="1 1 1"/>
            </geometry>
            <material name="material_caster_left">
                <color rgba="0.15 0.15 0.15 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/caster_left.STL" scale="1 1 1"/>
            </geometry>
        </collision>
    </link>

    <!-- ─────────────────────────────────────────────
        [LINKS] CASTER RIGHT
    ────────────────────────────────────────────── -->
    <link name="caster_right_link">
        <inertial>
            <origin xyz="-0.014 0.001 -0.033" rpy="0.0 0.0 0.0"/>
            <mass value="0.1"/>
            <inertia ixx="2.433E-05" ixy="3.222E-05" ixz="-2.152E-05" 
                    iyy="2.851E-05" iyz="3.766E-07" izz="2.982E-05"/>
        </inertial>

        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/caster_right.STL" scale="1 1 1"/>
            </geometry>
            <material name="material_caster_right">
                <color rgba="0.15 0.15 0.15 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/caster_right.STL" scale="1 1 1"/>
            </geometry>
        </collision>
    </link>

    <!-- ─────────────────────────────────────────────
        [LINKS] IMU
    ────────────────────────────────────────────── -->
    <link name="imu_link"/>

    <!-- ─────────────────────────────────────────────
        [LINKS] LIDAR
    ────────────────────────────────────────────── -->
      <link name="lidar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/lidar_hokuyo_ust10.stl" scale="1 1 1"/>
            </geometry>
            <material name="material_lidar">
                <color rgba="0.93 0.91 0.17 1.0"/>
            </material>
        </visual>
    </link>

    <!-- ─────────────────────────────────────────────
        [LINKS] CAMERA DEPTH
    ────────────────────────────────────────────── -->
      <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://robot_description/meshes/d435.dae" scale="1.1 1.1 1.1"/>
            </geometry>
        </visual>
    </link>

<!-- =============================================================== 
                            [JOINTS]
================================================================ -->
    <!-- ─────────────────────────────────────────────
        [JOINTS] BASE
    ────────────────────────────────────────────── -->
    <joint name="base_joint" type="fixed">
        <origin xyz="0.0 0.0 0.035" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] WHEEL LEFT
    ────────────────────────────────────────────── -->
    <joint name="wheel_left_joint" type="continuous">
        <origin xyz="0.155 0.144 0.044" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="wheel_left_link"/>
        <axis xyz="0 1 0"/>
        <limit effort="10.0" velocity="10.0"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] WHEEL RIGHT
    ────────────────────────────────────────────── -->
    <joint name="wheel_right_joint" type="continuous">
        <origin xyz="0.155 -0.144 0.044" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="wheel_right_link"/>
        <axis xyz="0 1 0"/>
        <limit effort="10.0" velocity="10.0"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] CASTER LEFT
    ────────────────────────────────────────────── -->
    <joint name="caster_left_joint" type="fixed">
        <origin xyz="-0.1 0.085 0.038" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="caster_left_link"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] CASTER RIGHT
    ────────────────────────────────────────────── -->
    <joint name="caster_right_joint" type="fixed">
        <origin xyz="-0.1 -0.085 0.038" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="caster_right_link"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] IMU
    ────────────────────────────────────────────── -->
    <joint name="imu_joint" type="fixed">
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="imu_link"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] LIDAR
    ────────────────────────────────────────────── -->
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0.318 0 0.084" rpy="0 0 0"/>
    </joint>

    <!-- ─────────────────────────────────────────────
        [JOINTS] CAMERA DEPTH
    ────────────────────────────────────────────── -->
    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="0.08 0 1.168" rpy="0 0 0"/>
    </joint>

<!-- =============================================================== 
                            [SENSORS]
================================================================ -->
    <!-- ─────────────────────────────────────────────
        [SENSOR] IMU
    ────────────────────────────────────────────── -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu"  >
            <ignition_frame_id>imu_link</ignition_frame_id>
            <always_on>1</always_on>
            <update_rate>50</update_rate>
            <visualize>false</visualize>
            <topic>/imu/data</topic>
            <imu>
                <enable_orientation>1</enable_orientation>
                <angular_velocity>
                    <x>
                        <noise type="gaussian">
                            <mean>0</mean>
                            <stddev>0.009</stddev>
                            <bias_mean>0.00075</bias_mean>
                            <bias_stddev>0.005</bias_stddev>
                            <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                            <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                            <precision>0.00025</precision>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0</mean>
                            <stddev>0.009</stddev>
                            <bias_mean>0.00075</bias_mean>
                            <bias_stddev>0.005</bias_stddev>
                            <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                            <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                            <precision>0.00025</precision>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0</mean>
                            <stddev>0.009</stddev>
                            <bias_mean>0.00075</bias_mean>
                            <bias_stddev>0.005</bias_stddev>
                            <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                            <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                            <precision>0.00025</precision>
                        </noise>
                    </z>
                </angular_velocity>
                <linear_acceleration>
                    <x>
                        <noise type="gaussian">
                            <mean>0</mean>
                            <stddev>0.021</stddev>
                            <bias_mean>0.05</bias_mean>
                            <bias_stddev>0.0075</bias_stddev>
                            <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                            <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                            <precision>0.005</precision>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0</mean>
                            <stddev>0.021</stddev>
                            <bias_mean>0.05</bias_mean>
                            <bias_stddev>0.0075</bias_stddev>
                            <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                            <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                            <precision>0.005</precision>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0</mean>
                            <stddev>0.021</stddev>
                            <bias_mean>0.05</bias_mean>
                            <bias_stddev>0.0075</bias_stddev>
                            <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                            <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                            <precision>0.005</precision>
                        </noise>
                    </z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- ─────────────────────────────────────────────
        [SENSOR] LIDAR
    ────────────────────────────────────────────── -->
    <gazebo reference="lidar_link">
        <sensor name='gpu_lidar' type='gpu_lidar'>
            <ignition_frame_id>lidar_link</ignition_frame_id> 
            <update_rate>10</update_rate>
            <always_on>1</always_on>
            <visualize>true</visualize>
            <topic>/lidar/data</topic>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-2.0944</min_angle>
                        <max_angle>2.0944</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.2</min>
                    <max>10.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
        </sensor>
    </gazebo>

    <!-- ─────────────────────────────────────────────
        [SENSOR] CAMERA DEPTH
    ────────────────────────────────────────────── -->
    <gazebo reference="camera_link">
        <sensor name="rgbd_camera" type="rgbd_camera">
            <ignition_frame_id>camera_link</ignition_frame_id>
            <camera name="rgbd_camera_frame">
            <always_on>1</always_on>
            <update_rate>5</update_rate>
            <visualize>0</visualize>
            <horizontal_fov>1.3962634</horizontal_fov>
            <lens>
                <intrinsics>
                    <fx>277.1</fx>
                    <fy>277.1</fy>
                    <cx>320.5</cx>
                    <cy>240.5</cy>
                    <s>0</s>
                </intrinsics>
            </lens>
            <distortion>
                <k1>0.104207</k1>
                <k2>-0.255558</k2>
                <k3>0.128694</k3>
                <p1>0.000512</p1>
                <p2>0.000319</p2>
                <center>0.5 0.5</center>
            </distortion>
            <image>
                <width>640</width>
                <height>480</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.1</near>
                <far>10</far>
            </clip>
            <depth_camera>
                <clip>
                    <near>0.1</near>
                    <far>10</far>
                </clip>
            </depth_camera>
            <noise>
                <type>gaussian</type>
                <mean>0</mean>
                <stddev>0.003</stddev>
            </noise>
            </camera>
        </sensor>
    </gazebo>

<!-- =============================================================== 
                            [PLUGINS]
================================================================ -->
    <!-- ─────────────────────────────────────────────
        [GAZEBO] 
    ────────────────────────────────────────────── -->
    <gazebo>
        <!-- ─────────────────────────────────────────────
            [PLUGINS] JOINT STATE PUBLISHER
        ────────────────────────────────────────────── -->
        <plugin filename="ignition-gazebo-joint-state-publisher-system"
                name="ignition::gazebo::systems::JointStatePublisher">
        </plugin>

        <!-- ─────────────────────────────────────────────
            [PLUGINS] DIFF DRIVE
        ────────────────────────────────────────────── -->
        <plugin filename="ignition-gazebo-diff-drive-system"
                name="ignition::gazebo::systems::DiffDrive">
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <tf_topic>/tf</tf_topic>
            <topic>/cmd_vel</topic>
            <odom_topic>/diff_drive/odom</odom_topic>

            <left_joint>wheel_left_joint</left_joint>
            <right_joint>wheel_right_joint</right_joint>
            <wheel_separation>0.50</wheel_separation>
            <wheel_radius>0.0792</wheel_radius>
        </plugin>

        <!-- ─────────────────────────────────────────────
            [PLUGIN] ODOMETRY PUBLISHER
        ────────────────────────────────────────────── -->
        <plugin filename="ignition-gazebo-odometry-publisher-system"
                name="ignition::gazebo::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
            <odom_topic>/odom_publisher/odom</odom_topic>
            <odom_covariance_topic>/odom_publisher/odom_with_covariance</odom_covariance_topic>
            <tf_topic>/odom_publisher/pose</tf_topic>
        </plugin>

         <!-- ─────────────────────────────────────────────
            [PLUGIN] POSE PUBLISHERS
        ────────────────────────────────────────────── -->
        <plugin filename="ignition-gazebo-pose-publisher-system"
                name="ignition::gazebo::systems::PosePublisher">
            <publish_link_pose>false</publish_link_pose>
            <publish_sensor_pose>false</publish_sensor_pose>
            <publish_collision_pose>false</publish_collision_pose>
            <publish_visual_pose>false</publish_visual_pose>
            <publish_nested_model_pose>true</publish_nested_model_pose>
            <update_frequency>50</update_frequency>
        </plugin>

    </gazebo>

</robot>
